# Copier vers .env et remplir les valeurs
# NE PAS committer .env

DB_HOST=localhost
DB_NAME=votre_db_name
DB_USER=votre_db_user
DB_PASS=votre_db_password

# Générer avec: openssl rand -hex 32
API_SECRET_TOKEN=

# Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=contact@novusepoxy.ca
RESEND_WEBHOOK_SECRET=whsec_...

# URL du dashboard (pour CORS)
DASHBOARD_URL=https://dashboard.novusepoxy.ca
