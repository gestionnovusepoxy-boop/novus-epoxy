# Copier vers .env.local — NE PAS committer

# NextAuth
NEXTAUTH_URL=https://dashboard.novusepoxy.ca
NEXTAUTH_SECRET=      # openssl rand -base64 32
AUTH_SECRET=          # même valeur

# Admin (seul email autorisé)
ADMIN_EMAIL=admin@novusepoxy.ca

# Resend (magic links)
RESEND_API_KEY=re_...
EMAIL_FROM=dashboard@novusepoxy.ca

# API Hostinger
NEXT_PUBLIC_API_BASE_URL=https://novusepoxy.ca
API_SECRET_TOKEN=     # même valeur que côté Hostinger
