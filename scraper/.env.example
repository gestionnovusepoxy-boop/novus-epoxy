# Novus Epoxy Scraper — required env vars
# Copy to .env and fill values. Never commit .env.

# Required — bearer token shared with dashboard for /api/* auth
ADMIN_API_KEY=

# Optional — dashboard URL for /scrape/bulk-import POSTs
DASHBOARD_URL=https://novus-epoxy.vercel.app

# Optional — scrape request timeout in seconds (default: 15)
SCRAPE_TIMEOUT=15
